# ===== PRODUCCIÓN WEBUZO =====
# Copia este archivo como .env y completa los valores reales
# NUNCA subas el archivo .env al servidor de control de versiones

# Genera una clave segura con: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=cambia-esto-por-una-clave-segura-de-50-caracteres

DEBUG=False
ALLOWED_HOSTS=asesoriasisapres.com,www.asesoriasisapres.com

# Base de datos MySQL (Webuzo panel -> MySQL/MariaDB)
# Deja DB_NAME vacío para usar SQLite (más simple, válido para empezar)
DB_NAME=usuario_asesoriasisapres
DB_USER=usuario_db
DB_PASSWORD=contraseña_segura_aqui
DB_HOST=localhost
DB_PORT=3306
DB_ENGINE=mysql

# Notificaciones por email (Resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
ASESOR_EMAIL=contacto@asesoriasisapres.com
ASESOR_WHATSAPP=56964345927

# Chat en vivo Tawk.to (opcional - obtén el ID en tawk.to)
TAWKTO_ID=
